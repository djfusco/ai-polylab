# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is listed in .gitignore.

# Required: OpenAI API key (used server-side only — never exposed to the browser)
OPENAI_API_KEY=

# Optional: override the default model (defaults to gpt-4.1-mini if unset)
OPENAI_MODEL=gpt-4.1-mini
